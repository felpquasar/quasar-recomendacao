{
  "name": "quasar-recomendacao-backend",
  "version": "1.0.0",
  "description": "Sistema de recomendação de produtos para Quasar Barber - TCC 2026",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "test:unit": "jest tests/unit --forceExit",
    "test:integration": "jest tests/integration",
    "test:coverage": "jest --coverage",
    "seed": "node src/database/seed.js"
  },
  "keywords": [
    "recomendacao",
    "association-rules",
    "barbershop"
  ],
  "author": "Felipe Pereira",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.38.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "knex": "^3.0.1",
    "pg": "^8.11.3",
    "redis": "^5.12.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js"
    ]
  }
}
